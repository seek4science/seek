<div class="landing_page">
  <h1>410</h1>
  <% asset_type = t("#{controller_name.singularize}") %>
  <h2>The requested <%= asset_type %> does not exist anymore.</h2>

  <p>The <%= asset_type %> with identifier <%= doi_link(retract_log[:doi]) %> has been retracted.</p>
  <% if retract_log.metadata.present? %>
    <p>
      <i><%= retract_log.metadata['title'] if retract_log.metadata['title'].present? %></i>
      <% names = Array(retract_log.metadata['creators']).filter_map { |c| c['last_name'].presence || c['first_name'].presence } %>
      <%= names.join(', ') if names.any? %>
      <%= retract_log.metadata['year'] if retract_log.metadata['year'].present? %>
      <%= retract_log.metadata['publisher'] if retract_log.metadata['publisher'].present? %>
    </p>
  <% end %>
  <% if retract_log[:comment].present? %>
    <p>The authors have left the following reason for retracting this <%= asset_type %>:</p>
    <p class="comment text-center"><%= sanitize(retract_log[:comment]) %></p>
  <% end %>
</div>